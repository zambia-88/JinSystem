# Waline 服务端环境变量（Vercel → Settings → Environment Variables）
# 部署根目录设为 waline-server，配置后 Redeploy

SITE_NAME=JinSystem
SITE_URL=https://jinsystem.cn
SERVER_URL=https://你的-waline.vercel.app
LOGIN=force
COMMENT_AUDIT=true
SECURE_DOMAINS=jinsystem.cn

# Neon PostgreSQL（Vercel Storage 创建后自动注入，或手动配置 PG_*）
# JWT_TOKEN=随机长字符串

AUTHOR_EMAIL=Jinsystem@gmail.com

# 可选：SMTP 用于注册验证与新留言通知
# SMTP_SERVICE=
# SMTP_USER=
# SMTP_PASS=
